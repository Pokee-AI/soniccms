---
import { apiConfig } from "../../../db/routes";
import { getFieldDefinitions } from "../../../services/fields";
import TextField from "./fields/text-field.astro";
import TextArea from "./fields/text-area.astro";
import FileUploadField from "./fields/file-upload-field.astro";
import SelectField from "./fields/select-field.astro";
import DateTimeField from "./fields/datetime-field.astro";

const { record, title = "Edit" } = Astro.props;
const { form } = Astro.params;
const tableConfigRecord = apiConfig.find((t) => t.route === form);
const tableConfig = getFieldDefinitions(tableConfigRecord, record);

// Build a "Preview" link for blog content. It opens the post on a
// development-mode site (dev.pokee.ai, or localhost) where draft posts render
// directly — so no secret or auth is needed. Production (pokee.ai) hides
// drafts, so it must NOT be used as the preview target. Only shown when
// editing an existing post (we need its slug).
const env = (Astro.locals.runtime?.env ?? {}) as unknown as Record<
  string,
  string | undefined
>;
const siteUrl = env.BLOG_PREVIEW_SITE_URL || "https://dev.pokee.ai";
const isBlogForm = form === "generalPost" || form === "comparisonPosts";
const previewUrl =
  isBlogForm && record?.slug
    ? `${siteUrl}/blog/${encodeURIComponent(record.slug)}`
    : null;

// Optional metadata (card display / categorization) tucked into a collapsible
// so the main form stays focused on writing the post.
const ADVANCED_FIELD_KEYS = ["competitorName", "integrationName", "hook"];
const mainFields = tableConfig.formFields.filter(
  (field) => !ADVANCED_FIELD_KEYS.includes(field.key),
);
const advancedFields = tableConfig.formFields.filter((field) =>
  ADVANCED_FIELD_KEYS.includes(field.key),
);
---

<form method="post">
  <div class="space-y-12 mx-auto max-w-7xl">
    <div class="border-b border-border pb-12">
      <a
        href={`/admin/tables/${form}`}
        class="inline-flex items-center gap-1 rounded-md bg-black px-2.5 py-1.5 text-sm font-medium text-white hover:bg-gray-800"
        aria-label="Back to list"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 20 20"
          fill="currentColor"
          class="h-4 w-4"
        >
          <path
            fill-rule="evenodd"
            d="M17 10a.75.75 0 0 1-.75.75H5.612l4.158 3.96a.75.75 0 1 1-1.04 1.08l-5.5-5.25a.75.75 0 0 1 0-1.08l5.5-5.25a.75.75 0 1 1 1.04 1.08L5.612 9.25H16.25A.75.75 0 0 1 17 10Z"
            clip-rule="evenodd"
          />
        </svg>
        Back
      </a>
      <h2 class="mt-4 text-base font-semibold leading-7 text-foreground">
        {title}
        {tableConfigRecord.name}
      </h2>

      <div class="mt-10 grid grid-cols-1 gap-x-6 gap-y-8 sm:grid-cols-6">
        <div class="sm:col-span-4">
          {
            mainFields.map((field) => (
              <div class="mt-4">
                {((field.key.includes('MediaUrls') || field.key === 'mediaUrls' || field.key === 'coverMediaUrl') && field.type === "textField") ? (
                  <FileUploadField field={field} record={record} />
                ) : field.type === "select" ? (
                  <SelectField field={field} />
                ) : field.type === "datetime" ? (
                  <DateTimeField field={field} />
                ) : field.type === "textArea" ? (
                  <TextArea field={field} />
                ) : (
                  <TextField field={field} />
                )}
              </div>
            ))
          }

          {advancedFields.length > 0 && (
            <details class="group mt-8 rounded-md border border-border">
              <summary class="flex cursor-pointer list-none items-center justify-between p-4 text-sm font-semibold text-foreground hover:bg-muted">
                <span>More options — card display &amp; categorization</span>
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 20 20"
                  fill="currentColor"
                  class="h-4 w-4 transition-transform group-open:rotate-90"
                >
                  <path
                    fill-rule="evenodd"
                    d="M7.21 14.77a.75.75 0 0 1 .02-1.06L11.168 10 7.23 6.29a.75.75 0 1 1 1.04-1.08l4.5 4.25a.75.75 0 0 1 0 1.08l-4.5 4.25a.75.75 0 0 1-1.06-.02Z"
                    clip-rule="evenodd"
                  />
                </svg>
              </summary>
              <div class="border-t border-border px-4 pb-4">
                {advancedFields.map((field) => (
                  <div class="mt-4">
                    {((field.key.includes('MediaUrls') || field.key === 'mediaUrls' || field.key === 'coverMediaUrl') && field.type === "textField") ? (
                      <FileUploadField field={field} record={record} />
                    ) : field.type === "select" ? (
                      <SelectField field={field} />
                    ) : field.type === "datetime" ? (
                      <DateTimeField field={field} />
                    ) : field.type === "textArea" ? (
                      <TextArea field={field} />
                    ) : (
                      <TextField field={field} />
                    )}
                  </div>
                ))}
              </div>
            </details>
          )}

          <div class="mt-6 flex items-center justify-end gap-x-6">
            {previewUrl && (
              <a
                href={previewUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="mr-auto rounded-md bg-amber-500 px-3 py-2 text-sm font-semibold text-amber-950 shadow-sm hover:bg-amber-400"
                title="Save first to preview your latest changes"
                >👀 Preview ↗</a
              >
            )}
            <a
              href={`/admin/tables/${form}`}
              class="rounded-md bg-secondary px-3 py-2 text-sm font-semibold text-secondary-foreground shadow-sm hover:bg-secondary/80 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-gray-500"
              >Cancel</a
            >
            <button
              type="submit"
              class="rounded-md bg-primary px-3 py-2 text-sm font-semibold text-primary-foreground shadow-sm hover:bg-primary/90 font-medium focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-pokee-purple"
              >Save</button
            >
          </div>
          {previewUrl && (
            <p class="mt-2 text-right text-xs text-muted-foreground">
              Opens this post on the preview site (dev.pokee.ai), where drafts
              are visible before publishing. Save before previewing.
            </p>
          )}
        </div>
      </div>
    </div>
  </div>
</form>
