---
const { field } = Astro.props;
---

{
  field.type === "textArea" && (
    <div class="col-span-4">
      <label
        for={field.key}
        class="block text-sm font-medium leading-6 text-foreground"
      >
        {field.label || field.key}
      </label>
      <div class="mt-2">
        <textarea
          id={field.key}
          name={field.key}
          rows="3"
          class="block w-full rounded-md border-0 bg-background py-1.5 text-foreground shadow-sm ring-1 ring-inset ring-input focus:ring-2 focus:ring-inset focus:ring-pokee-purple sm:text-sm sm:leading-6"
        >{field.value}</textarea>
      </div>
      {field.hint && (
        <p class="mt-3 text-sm leading-6 text-muted-foreground">
          {field.hint}
        </p>
      )}
    </div>
  )
}
