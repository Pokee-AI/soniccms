---
const { field } = Astro.props;
const options = field.options ?? [];
const current = field.value ?? "";
---

{field.type === "select" && (
  <div class="sm:col-span-4">
    <label
      for={field.key}
      class="block text-sm font-medium leading-6 text-white"
    >
      {field.label || field.key}
    </label>
    <div class="mt-2">
      <select
        id={field.key}
        name={field.key}
        class="block w-full rounded-md border-0 bg-white/5 py-1.5 pl-2 text-white shadow-sm ring-1 ring-inset ring-white/10 focus:ring-2 focus:ring-inset focus:ring-indigo-500 sm:text-sm sm:leading-6 [&>option]:bg-gray-800"
      >
        {options.map((opt) => {
          const value = typeof opt === "string" ? opt : opt.value;
          const optLabel = typeof opt === "string" ? opt : (opt.label ?? opt.value);
          return (
            <option value={value} selected={String(current) === String(value)}>
              {optLabel}
            </option>
          );
        })}
      </select>
    </div>
    {field.hint && (
      <p class="mt-2 text-sm text-gray-400">{field.hint}</p>
    )}
  </div>
)}
