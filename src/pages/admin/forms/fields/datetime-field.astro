---
const { field } = Astro.props;

// Stored value is a unix-ms timestamp (or a numeric string). Convert it to the
// `YYYY-MM-DDTHH:mm` shape that <input type="datetime-local"> expects so the
// existing publication date shows up when editing.
function toLocalInputValue(value: unknown): string {
  if (value === null || value === undefined || value === "") return "";
  const ms =
    typeof value === "number"
      ? value
      : /^\d+$/.test(String(value))
        ? Number(value)
        : Date.parse(String(value));
  if (!ms || Number.isNaN(ms)) return "";
  const d = new Date(ms);
  const pad = (n: number) => String(n).padStart(2, "0");
  return `${d.getFullYear()}-${pad(d.getMonth() + 1)}-${pad(d.getDate())}T${pad(d.getHours())}:${pad(d.getMinutes())}`;
}

const value = toLocalInputValue(field.value);
---

{field.type === "datetime" && (
  <div class="sm:col-span-4">
    <label
      for={field.key}
      class="block text-sm font-medium leading-6 text-white"
    >
      {field.label || field.key}
    </label>
    <div class="mt-2">
      <input
        type="datetime-local"
        id={field.key}
        name={field.key}
        value={value}
        class="block w-full rounded-md border-0 bg-white/5 py-1.5 pl-2 text-white shadow-sm ring-1 ring-inset ring-white/10 focus:ring-2 focus:ring-inset focus:ring-indigo-500 sm:text-sm sm:leading-6 [color-scheme:dark]"
      />
    </div>
    {field.hint && (
      <p class="mt-2 text-sm text-gray-400">{field.hint}</p>
    )}
  </div>
)}
